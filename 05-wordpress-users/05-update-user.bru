meta {
  name: 05 Update User
  type: http
  seq: 5
}

put {
  url: {{base_url}}/wp-json/wp/v2/users/{{user_id}}
  body: json
}

auth:basic {
  username: {{username}}
  password: {{app_password}}
}

body:json {
  {
    "first_name": "Updated",
    "last_name": "Name",
    "roles": ["editor"]
  }
}

docs {
  Ενημερώνει στοιχεία user
}
