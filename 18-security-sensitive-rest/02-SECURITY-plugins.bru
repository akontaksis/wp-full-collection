meta {
  name: "[SECURITY] Plugins List - Anonymous"
  type: http
  seq: 2
}

get {
  url: {{base_url}}/wp-json/wp/v2/plugins
}

assert {
  res.status: eq 401
}

tests {
  test("Plugins endpoint must require authentication", function() {
    expect(res.status).to.equal(401);
  });
}

docs {
