meta {
  name: "[SECURITY] WC Customers - Anonymous"
  type: http
  seq: 5
}

get {
  url: {{base_url}}/wp-json/wc/v3/customers
}

assert {
  res.status: eq 401
}

tests {
  test("Customers endpoint must require authentication - GDPR", function() {
    expect(res.status).to.equal(401);
  });
}

docs {
