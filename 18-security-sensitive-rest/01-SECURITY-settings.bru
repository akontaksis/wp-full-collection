meta {
  name: "[SECURITY] WP Settings - Anonymous"
  type: http
  seq: 1
}

get {
  url: {{base_url}}/wp-json/wp/v2/settings
}

assert {
  res.status: eq 401
}

tests {
  test("Settings endpoint must require authentication", function() {
    expect(res.status).to.equal(401);
  });
}

docs {
  Αναμενόμενο: 401
  Αν 200 = εκθέτει site email, timezone, blogname
}
