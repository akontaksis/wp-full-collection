meta {
  name: "[SECURITY] Themes - Anonymous"
  type: http
  seq: 3
}

get {
  url: {{base_url}}/wp-json/wp/v2/themes
}

assert {
  res.status: eq 401
}

tests {
  test("Themes endpoint must require authentication", function() {
    expect(res.status).to.equal(401);
  });
}

docs {
  Αναμενόμενο: 401
  Αν 200 = εκθέτει active theme και version
}
