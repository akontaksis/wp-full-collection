meta {
  name: "[SECURITY] Git Config"
  type: http
  seq: 7
}

get {
  url: {{base_url}}/.git/config
}

assert {
  res.status: in [403, 404]
}

tests {
  test(".git directory must not be publicly accessible", function() {
    expect(res.status).to.be.oneOf([403, 404]);
  });
}

docs {
  Αναμενόμενο: 403 ή 404
  Αν 200 = εκθέτει git repository info
}
