meta {
  name: "[SECURITY] Debug Log"
  type: http
  seq: 1
}

get {
  url: {{base_url}}/wp-content/debug.log
}

assert {
  res.status: in [403, 404]
  res.responseTime: lt 5000
}

tests {
  test("Debug log must not be publicly accessible", function() {
    expect(res.status).to.be.oneOf([403, 404]);
  });
}

docs {
  Αναμενόμενο: 403 ή 404
  Αν 200 = εκθέτει PHP errors με paths και passwords
}
