meta {
  name: "[SECURITY] Env File"
  type: http
  seq: 4
}

get {
  url: {{base_url}}/.env
}

assert {
  res.status: in [403, 404]
}

tests {
  test(".env file must not be publicly accessible", function() {
    expect(res.status).to.be.oneOf([403, 404]);
  });
}

docs {
  Αναμενόμενο: 403 ή 404
  Αν 200 = εκθέτει API keys, secrets
}
