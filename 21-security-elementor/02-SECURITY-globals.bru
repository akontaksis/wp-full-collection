meta {
  name: "[SECURITY] Elementor Globals - Anonymous"
  type: http
  seq: 2
}

get {
  url: {{base_url}}/wp-json/elementor/v1/globals
}

assert {
  res.status: eq 401
}

tests {
  test("Elementor globals must require authentication", function() {
    expect(res.status).to.equal(401);
  });
}

