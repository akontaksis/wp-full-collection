meta {
  name: "[SECURITY] Elementor Templates - Anonymous"
  type: http
  seq: 3
}

get {
  url: {{base_url}}/wp-json/elementor/v1/templates
}

assert {
  res.status: eq 401
}

tests {
  test("Elementor templates must require authentication", function() {
    expect(res.status).to.equal(401);
  });
}

